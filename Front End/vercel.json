{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://prudent-farsighted-yareli.ngrok-free.dev/api/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "https://prudent-farsighted-yareli.ngrok-free.dev/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://ecommerce-template-xi-tan.vercel.app/"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}