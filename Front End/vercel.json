{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ecommerce-template-api-mu.vercel.app/api/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "https://ecommerce-template-xi-tan.vercel.app/images/$1"
    },
    {
      "source": "/(.*)",
      "destination": "https://ecommerce-template-xi-tan.vercel.app/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}